import sqlite3

DB_NAME = "channels.db"


def create_tables():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    cur.execute("""
        CREATE TABLE IF NOT EXISTS channels (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            channel TEXT UNIQUE NOT NULL
        )
    """)

    conn.commit()
    conn.close()


def add_channel(channel):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    try:
        cur.execute(
            "INSERT INTO channels (channel) VALUES (?)",
            (channel,)
        )
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()


def remove_channel(channel):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    cur.execute(
        "DELETE FROM channels WHERE channel=?",
        (channel,)
    )

    conn.commit()
    conn.close()


def get_channels():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    cur.execute("SELECT channel FROM channels")

    rows = cur.fetchall()

    conn.close()

    return [row[0] for row in rows]


def channel_exists(channel):
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    cur.execute(
        "SELECT 1 FROM channels WHERE channel=?",
        (channel,)
    )

    result = cur.fetchone()

    conn.close()

    return result is not None


def get_channel_count():
    return len(get_channels())


def clear_channels():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()

    cur.execute("DELETE FROM channels")

    conn.commit()
    conn.close()
